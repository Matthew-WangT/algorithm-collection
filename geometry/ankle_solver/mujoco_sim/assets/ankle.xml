<mujoco>
    <option gravity="0 0 0" timestep="0.002" />
    <asset>
        <material name="blue_" rgba="0 0 1 1" />
        <material name="green" rgba="0 1 0 1" />
        <material name="red__" rgba="1 0 0 1" />
        <material name="white" rgba="1 1 1 1" />
    </asset>
    <worldbody>
        <geom type="plane" size="10 10 0.1" pos="0 0 -2" rgba=".1 0 0.6 1" />
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1" />
        <body name="base_link" pos="0 0 0">
            <geom  contype="0" conaffinity="0" type="capsule" size="0.01" fromto="0 0 0.05 0 0 0.1" material="red__" />
            <body name="l_bar" pos="0 0.05 0.1" euler="0 0 0">
                <joint name="ankle_l_joint" pos="0 0 0" axis="0 1 0" range="-50 50"/>
                <geom type="capsule" size=".01" fromto="0 0 0 0.04 0 0" material="green" />
                <body name="l_link" pos="0.04 0 0" euler="0 0 0">
                    <joint name="l_link_hinge" pos="0 0 0" axis="0 1 0" type="ball"/>
                    <geom  contype="0" conaffinity="0" type="capsule" size=".01" fromto="0 0 0 0 0 -0.1" material="white" />
                </body>
            </body>
            <body name="r_bar" pos="0 -0.05 0.1" euler="0 0 0">
                <joint name="ankle_r_joint" pos="0 0 0" axis="0 1 0" range="-50 50"/>
                <geom type="capsule" size=".01" fromto="0 0 0 0.04 0 0" material="green" />
                <body name="r_link" pos="0.04 0 0" euler="0 0 0">
                    <joint name="r_link_hinge" pos="0 0 0" axis="0 1 0" type="ball"/>
                    <geom  contype="0" conaffinity="0" type="capsule" size=".01" fromto="0 0 0 0 0 -0.1" material="white" />
                </body>
            </body>
            <body name="ankle_pitch_link" pos="0 0 0.0" euler="0 0 0">
                <joint name="ankle_pitch_joint" pos="0 0 0" axis="0 1 0" range="-50 50" type="hinge"/>
                <geom contype="0" conaffinity="0" type="capsule" size=".01 0.05" pos="0 0 0" euler="90 0 0" material="blue_" />
                <body name="ankle_roll_link" pos="0 0 0.0" euler="0 0 0">
                    <joint name="ankle_roll_joint" pos="0 0 0" axis="1 0 0" range="-30 30" type="hinge" />
                    <geom contype="0" conaffinity="0" type="box" size=".1 0.08 0.01" pos="0 0 0" euler="0 0 0" material="green" />
                </body>
            </body>
        </body>
    </worldbody>
    <equality>
        <connect name="kinematic_link_l" active="true" body1="ankle_roll_link" body2="l_link" anchor="0.04 0.05 0" solref="0.001 1"/>
        <connect name="kinematic_link_r" active="true" body1="ankle_roll_link" body2="r_link" anchor="0.04 -0.05 0" />
    </equality>
    <actuator>
        <motor name="ankle_pitch_motor" joint="ankle_pitch_joint"/>
        <motor name="ankle_roll_motor" joint="ankle_roll_joint"/>
        <motor name="ankle_l_motor" joint="ankle_l_joint"/>
        <motor name="ankle_r_motor" joint="ankle_r_joint"/>
    </actuator>
</mujoco>